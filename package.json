{
  "name": "findmyspot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Find nearby ADA-accessible parking spots in Portland, OR using OpenStreetMap + groundingDino sign detection.",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx api/local-dev-server.ts",
    "dev:api:vercel": "npx vercel dev --listen 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^5.8.4",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.22.3",
    "typescript": "^5.5.3",
    "vite": "^8.0.14"
  }
}
