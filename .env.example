# Hugging Face Inference API token — used to call groundingDino for ADA sign detection.
# Get one at https://huggingface.co/settings/tokens (read-only is sufficient).
# If unset, the app still works but falls back to OSM-tag-only accessibility scoring.
HUGGINGFACE_API_TOKEN=

# Mapillary client access token (v4) — used to fetch street-level imagery for detection.
# Get one at https://www.mapillary.com/dashboard/developers.
# If unset, sign-detection is skipped (results still render).
MAPILLARY_CLIENT_TOKEN=

# Google Maps Platform — Geocoding API key. REQUIRED.
# Create one at https://console.cloud.google.com/google/maps-apis/credentials
# Restrict the key to the Geocoding API only; we keep it server-side so no
# HTTP-referer restriction is appropriate.
GOOGLE_GEOCODING_API_KEY=
